{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vplayer",
  "version": "0.1.0",
  "identifier": "com.johnje.vplayer",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "vplayer",
        "width": 800,
        "height": 600,
        "maximized": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      },
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost; media-src 'self' memvideo: blob: data:; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "cli": {
      "args": [
        {
          "name": "password",
          "short": "p",
          "takesValue": true
        }
      ]
    }
  }
}
